# Configuração da consulta-nfse-api
# Copie este arquivo para .env e preencha com seus dados

# Caminho absoluto do certificado digital A1 (.pfx ou .p12)
# Ex: C:/caminho/para/certificado.pfx
NFSE_CERTIFICADO_PFX=

# Senha do certificado A1
NFSE_SENHA_CERTIFICADO=

# Ambiente: producao (padrão) ou homologacao
NFSE_AMBIENTE=producao

# CNPJ do prestador (opcional — será extraído do certificado automaticamente)
NFSE_CNPJ_PRESTADOR=
